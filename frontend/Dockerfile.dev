# EACY Frontend Dockerfile - 开发环境（热更新）
# 使用 Vite 开发服务器，支持 HMR

FROM node:18-alpine

WORKDIR /app

# 安装依赖
COPY package.json package-lock.json* ./

# 安装所有依赖（包括 devDependencies）
RUN npm ci --registry=https://registry.npmmirror.com --no-audit --no-fund

# 复制源代码（开发模式下会被 volume 覆盖）
COPY . .

# 暴露 Vite 开发服务器端口
EXPOSE 5173

# 启动 Vite 开发服务器
# --host 0.0.0.0 允许外部访问
# --strictPort 强制使用指定端口
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--strictPort"]
